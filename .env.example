# ChatBI 生产部署环境变量
# 复制此文件为 .env 并填写实际值: cp .env.example .env

# ===== 必填 =====
# DashScope API 密钥（AI 模型 + Embedding）
DASHSCOPE_API_KEY=sk-your-api-key-here

# JWT 签名密钥（请使用足够长的随机字符串）
JWT_SECRET=your-jwt-secret-key-here

# ===== 可选 =====
# 数据库配置（默认值适用于 Docker 内部网络）
# DB_NAME=chatbi
# DB_USER=postgres
# DB_PASSWORD=postgres

# 前端暴露端口
# WEB_PORT=80

# Embedding 模型（一般无需修改）
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_MODEL=text-embedding-v3
# EMBEDDING_DIMENSIONS=1024

# MCP 远程工具服务
# MCP_SERVER_URL=http://chatbi-mcp:8000/mcp
# MCP_SERVER_TRANSPORT=streamable-http

# Langfuse 观测链路（启用后 Java 服务会通过 OTLP 导出到 Langfuse）
# LANGFUSE_ENABLED=true
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
# LANGFUSE_ENVIRONMENT=production
# CHATBI_RELEASE=2026.03.09
